#!/usr/bin/env python3

from __future__ import annotations

import argparse
import shutil
import sys
from pathlib import Path


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="scripts/install-skills",
        usage="scripts/install-skills [options] [skill ...]",
    )
    parser.add_argument(
        "--target",
        default="~/.agents/skills",
        metavar="DIR",
        help="Install target. Default: ~/.agents/skills",
    )
    parser.add_argument(
        "--mode",
        default="symlink",
        metavar="MODE",
        help="symlink or copy. Default: symlink",
    )
    parser.add_argument(
        "--dry-run", action="store_true", help="Print actions without changing files"
    )
    parser.add_argument(
        "--force", action="store_true", help="Replace an existing skill at the target path"
    )
    parser.add_argument("--list", action="store_true", help="List available skills and exit")
    parser.add_argument("skills", nargs="*")
    return parser.parse_args(argv)


def same_real_path(left: Path, right: Path) -> bool:
    try:
        return left.resolve(strict=True) == right.resolve(strict=True)
    except FileNotFoundError:
        return False


def remove_path(path: Path) -> None:
    if path.is_symlink() or path.is_file():
        path.unlink()
    else:
        shutil.rmtree(path)


def main(argv: list[str] | None = None) -> int:
    args = parse_args(sys.argv[1:] if argv is None else argv)
    if args.mode not in {"symlink", "copy"}:
        print(f"invalid --mode: {args.mode}", file=sys.stderr)
        return 2

    root = Path(__file__).resolve().parent.parent
    skills_root = root / "skills"
    available = sorted(
        path.name for path in skills_root.iterdir() if (path / "SKILL.md").is_file()
    )

    if args.list:
        print("\n".join(available))
        return 0

    selected = available if not args.skills else args.skills
    missing = [name for name in selected if name not in available]
    if missing:
        print(f"unknown skill(s): {', '.join(missing)}", file=sys.stderr)
        print(f"available: {', '.join(available)}", file=sys.stderr)
        return 1

    target_root = Path(args.target).expanduser().absolute()
    if not args.dry_run:
        target_root.mkdir(parents=True, exist_ok=True)

    for name in selected:
        source = skills_root / name
        target = target_root / name

        if target.exists() or target.is_symlink():
            if not args.force:
                print(f"exists, skipping: {target}", file=sys.stderr)
                continue

            if not target.is_symlink() and same_real_path(source, target):
                print(f"target is source, skipping: {target}", file=sys.stderr)
                continue

            if args.dry_run:
                print(f"remove {target}")
            else:
                remove_path(target)

        if not args.dry_run:
            if args.mode == "symlink":
                target.symlink_to(source, target_is_directory=True)
            else:
                shutil.copytree(source, target)

        prefix = f"would {args.mode}" if args.dry_run else args.mode
        print(f"{prefix} {name} -> {target}")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
