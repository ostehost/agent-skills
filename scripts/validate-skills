#!/usr/bin/env python3

from __future__ import annotations

import json
import sys
from pathlib import Path

try:
    import yaml
except ModuleNotFoundError:
    print(
        "PyYAML is required; run: python3 -m pip install -r requirements-dev.txt",
        file=sys.stderr,
    )
    raise SystemExit(2)


class NoAliasSafeLoader(yaml.SafeLoader):
    def compose_node(self, parent: object, index: object) -> yaml.Node:
        if self.check_event(yaml.AliasEvent):
            event = self.get_event()
            raise yaml.YAMLError(f"YAML aliases are not allowed: {event.anchor}")
        return super().compose_node(parent, index)


def load_frontmatter(text: str) -> tuple[dict[object, object] | None, str | None]:
    if not text.startswith("---\n"):
        return None, "missing YAML frontmatter"

    close = frontmatter_end(text)
    if close == -1:
        return None, "unterminated YAML frontmatter"

    try:
        data = yaml.load(text[4:close], Loader=NoAliasSafeLoader) or {}
    except yaml.YAMLError as error:
        return None, f"invalid YAML: {error}"

    if not isinstance(data, dict):
        return None, "YAML frontmatter must be a mapping"
    return data, None


def frontmatter_end(text: str) -> int:
    """Return the offset of a closing delimiter that occupies its own line."""
    offset = 4
    while (close := text.find("\n---", offset)) != -1:
        after = close + 4
        if after == len(text) or text[after] == "\n":
            return close
        offset = after
    return -1


def validate_manifest(path: Path, available: set[str]) -> list[str]:
    if not path.exists():
        return []

    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as error:
        return [f"skills.sh.json: invalid JSON: {error}"]

    if not isinstance(data, dict):
        return ["skills.sh.json: top-level value must be a JSON object"]

    groupings = data.get("groupings")
    if groupings is None:
        return ['skills.sh.json: missing "groupings" array']
    if not isinstance(groupings, list):
        return ['skills.sh.json: "groupings" must be an array']

    errors: list[str] = []
    seen: set[str] = set()
    for index, grouping in enumerate(groupings, start=1):
        if not isinstance(grouping, dict):
            errors.append(f"skills.sh.json: grouping #{index} must be an object")
            continue

        title = grouping.get("title")
        label = title if isinstance(title, str) else f"#{index}"
        skills = grouping.get("skills", [])
        if not isinstance(skills, list):
            errors.append(
                f'skills.sh.json: grouping {label!r} "skills" must be an array'
            )
            continue

        for name in skills:
            if not isinstance(name, str):
                errors.append(
                    f"skills.sh.json: grouping {label!r} has a non-string skill entry {name!r}"
                )
                continue
            if name not in available:
                errors.append(
                    f"skills.sh.json: grouping {label!r} references unknown skill {name!r}"
                )
            if name in seen:
                errors.append(f"skills.sh.json: skill {name!r} is listed more than once")
            seen.add(name)

    return errors


def main() -> int:
    root = Path(__file__).resolve().parent.parent
    skill_files = sorted((root / "skills").glob("*/SKILL.md"))

    if not skill_files:
        print("No skills/*/SKILL.md files found.", file=sys.stderr)
        return 1

    errors: list[str] = []
    for path in skill_files:
        rel = path.relative_to(root)
        data, error = load_frontmatter(path.read_text(encoding="utf-8"))
        if error is not None:
            errors.append(f"{rel}: {error}")
            continue

        assert data is not None
        name = data.get("name")
        description = data.get("description")
        valid_name = isinstance(name, str) and bool(name.strip())
        if not valid_name:
            errors.append(f"{rel}: missing name")
        elif name != path.parent.name:
            errors.append(
                f"{rel}: name {name!r} does not match directory {path.parent.name!r}"
            )
        if not isinstance(description, str) or not description.strip():
            errors.append(f"{rel}: missing description")

    available = {path.parent.name for path in skill_files}
    manifest = root / "skills.sh.json"
    errors.extend(validate_manifest(manifest, available))

    if errors:
        print("\n".join(errors), file=sys.stderr)
        return 1

    print(f"validated {len(skill_files)} skills")
    if manifest.exists():
        print(f"validated skills.sh.json against {len(available)} skills")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
