{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "FROZEN primitives. DTCG 2025.10 color OBJECT form (colorSpace+components). Generated by `just expand-ramps` (pure: no randomness/time/network). Do not hand-edit.",
  "color": {
    "$type": "color",
    "neutral": {
      "50":  { "$value": { "colorSpace": "oklch", "components": [0.985, 0.002, 247], "hex": "#fafafa" } },
      "500": { "$value": { "colorSpace": "oklch", "components": [0.62, 0.01, 247], "hex": "#737373" } },
      "900": { "$value": { "colorSpace": "oklch", "components": [0.22, 0.01, 247], "hex": "#1f1f1f" } }
    },
    "accent": {
      "500": { "$value": { "colorSpace": "oklch", "components": [0.62, 0.16, 35], "hex": "#c25a3a" } }
    }
  },
  "spacing": {
    "$type": "dimension",
    "1": { "$value": { "value": 4, "unit": "px" } },
    "2": { "$value": { "value": 8, "unit": "px" } },
    "4": { "$value": { "value": 16, "unit": "px" } },
    "8": { "$value": { "value": 32, "unit": "px" } }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": { "value": 4, "unit": "px" } },
    "lg": { "$value": { "value": 16, "unit": "px" } }
  }
}
